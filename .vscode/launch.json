{
    "version": "0.2.0",
    "configurations": [
        
      {
        "name": "Debug API",
        "type": "node",
        "request": "launch",
        "program": "${workspaceFolder}/src/app.js",
        "cwd": "${workspaceFolder}",
        "args": [],
